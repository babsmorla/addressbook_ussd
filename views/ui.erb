<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css">
    <title>USSD UI Simulator</title>
    <style>
      /* Base resets and configuration */
      *, *::before, *::after {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        display: flex;
        height: 100vh;
        align-items: center;
        justify-content: center;
        background-color: #f0f2f5;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Outer Phone Frame */
      .smartphone-frame {
        display: flex;
        height: 720px;
        width: 360px;
        border-radius: 44px;
        background-color: #111;
        padding: 14px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25);
      }

      /* Inner Phone Screen */
      .smartphone-screen {
        position: relative;
        display: flex;
        flex: 1 1 0%;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
        border-radius: 32px;
        background-color: #ffcc00;
        padding: 20px;
      }

      /* USSD Dialog Styling */
      .ussd-alert-box {
        margin-top: auto;
        margin-bottom: auto;
        width: 100%;
        border-radius: 16px;
        background-color: #ffffff;
        padding: 20px;
        box-shadow: 0 10px 18px rgba(0, 0, 0, 0.18);
      }

      .ussd-header {
        margin-bottom: 12px;
        word-break: break-word;
        font-size: 15px;
        font-weight: 700;
        color: #1a1a1a;
      }

      .ussd-row {
        margin-top: 6px;
        margin-bottom: 6px;
        word-break: break-word;
        font-size: 14px;
        color: #555555;
      }

      .ussd-form {
        margin: 0;
        width: 100%;
      }

      .ussd-input {
        margin-top: 14px;
        width: 100%;
        border: none;
        border-bottom: 2px solid #ffcc00;
        background-color: transparent;
        padding-top: 8px;
        padding-bottom: 8px;
        font-size: 16px;
        outline: 2px solid transparent;
        outline-offset: 2px;
      }

      .button-group {
        margin-top: 18px;
        display: flex;
        justify-content: flex-end;
        gap: 20px;
      }

      .action-btn {
        cursor: pointer;
        padding: 4px;
        font-size: 14px;
        font-weight: 700;
        text-transform: uppercase;
        background: none;
        border: none;
      }

      .action-btn.cancel {
        color: #888888;
      }

      .action-btn.send {
        color: #0066cc;
      }

      /* Dialer Elements */
      .dialer-container {
        width: 100%;
      }

      .dialer-display {
        margin-top: 20px;
        display: flex;
        height: 80px;
        align-items: center;
        justify-content: center;
        break-all: break-all;
        border-radius: 12px;
        background-color: #ffffff;
        padding-left: 10px;
        padding-right: 10px;
        font-size: 30px;
        font-weight: 700;
        letter-spacing: 2px;
      }

      .dialer-error {
        margin-top: 8px;
        text-align: center;
        font-size: 12px;
        font-weight: 600;
        color: #b91c1c;
      }

      /* Grid Layout adjustments */
      .dialpad-container {
        margin-bottom: 10px;
        display: grid;
        width: 100%;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
      }

      .key-btn {
        margin: auto;
        display: flex;
        height: 60px;
        width: 60px;
        cursor: pointer;
        align-items: center;
        justify-content: center;
        border-radius: 9999px;
        border: none;
        background-color: rgba(255, 255, 255, 0.3);
        font-size: 22px;
        font-weight: 600;
        transition: background-color 150ms, transform 150ms;
      }

      .key-btn:active {
        transform: scale(0.95);
        background-color: rgba(255, 255, 255, 0.5);
      }

      /* Bottom Action Layout blocks */
      .action-layout-group {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      .action-row {
        display: flex;
        justify-content: space-between;
        gap: 16px;
      }

      .btn-base {
        display: inline-block;
        height: 52px;
        cursor: pointer;
        border-radius: 30px;
        border: none;
        font-size: 14px;
        font-weight: 700;
        color: #ffffff;
      }

      .dial-btn {
        width: 70%;
        background-color: #2e7d32;
      }

      .clear-btn {
        width: 30%;
        background-color: #c62828;
      }

      .reset-btn {
        width: 100%;
        background-color: #1f2937; /* Gray-800 */
      }

      /* Debug Block */
      .debug-panel {
        width: 100%;
        overflow: hidden;
        border-radius: 8px;
        background-color: rgba(0, 0, 0, 0.05);
        padding: 8px;
        text-align: center;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 10px;
      }
    </style>
  </head>
  <body>
    <div class="smartphone-frame">
      <div class="smartphone-screen">
        <% if @display_message.present? && @dial_buffer.blank? %>
          <div class="ussd-alert-box">
            <div class="ussd-header">
              <%= @display_message.lines.first %>
            </div>
            <% @display_message.lines.drop(1).each do |line| %>
              <div class="ussd-row"><%= line %></div>
            <% end %>
            <form method="post" class="ussd-form">
              <input
                type="text"
                name="user_input"
                class="ussd-input"
                value="<%= @input_buffer %>"
                autocomplete="off"
                autofocus
              >
                <div class="button-group">
                  <button class="action-btn cancel" name="commit" value="Reset">
                    Cancel
                  </button>
                  <button class="action-btn send">
                    Send
                  </button>
                </div>
              </form>
            </div>
          <% else %>
            <div class="dialer-container">
              <div class="dialer-display">
                <%= @dial_buffer.presence || "—" %>
              </div>
              <% if @error_message %>
                <div class="dialer-error">
                  <%= @error_message %>
                </div>
              <% end %>
            </div>
            <form method="post" class="ussd-form">
              <div class="dialpad-container">
                <% %w[1 2 3 4 5 6 7 8 9 * 0 #].each do |digit| %>
                  <button class="key-btn" name="key_value" value="<%= digit %>">
                    <%= digit %>
                  </button>
                <% end %>
              </div>
              <div class="action-layout-group">
                <div class="action-row">
                  <button class="btn-base dial-btn" name="commit" value="Send">
                    Dial
                  </button>
                  <button class="btn-base clear-btn" name="commit" value="Clear">
                    Clear
                  </button>
                </div>
                <button class="btn-base reset-btn" name="commit" value="Reset">
                  Reset
                </button>
              </div>
            </form>
          <% end %>
          <div class="debug-panel">
            Session: <%= @session_id %>
          </div>
        </div>
      </div>
    </body>
  </html>